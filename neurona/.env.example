# ─────────────────────────────────────────────────────────────
# Copia este archivo a .env en el servidor y ajusta los valores.
# NUNCA subas .env al repositorio (.gitignore ya lo excluye).
# ─────────────────────────────────────────────────────────────

# Limite de peticiones por minuto por IP (default 60)
RATE_LIMIT_PER_MIN=60

# Python no genera archivos .pyc en produccion
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
